---
import 'animal-island-ui/style';
import App from '../components/App';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Rosanne Vázquez — Software Engineer. React, TypeScript, Python, and AI. Building meaningful web and mobile applications." />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Rosanne Vázquez | Software Engineer" />
    <meta property="og:description" content="Software Engineer building meaningful web and mobile applications with React, TypeScript, Python, and AI." />
    <meta property="og:image" content="/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/og-image.svg" />
    <title>Rosanne Vázquez | Software Engineer</title>
    <style>
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: #f8f8f0;
        min-height: 100vh;
      }
      * {
        box-sizing: border-box;
      }
      section {
        scroll-margin-top: 24px;
      }
      @media (max-width: 768px) {
        section {
          scroll-margin-top: 12px;
        }
      }
    </style>
  </head>
  <body>
    <App client:load />
  </body>
</html>
